# Application
PORT=8882
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:password@localhost:5432/data_loggers_db
REDIS_URL=redis://127.0.0.1:6379

DEFAULT_LOG_LIMIT=50
MAX_QUERY_LIMIT=300
SUMMARY_SAMPLE_LIMIT_PER_SITE=50
DB_STATEMENT_TIMEOUT_MS=15000
EXPECTED_LOGS_PER_DAY=240

# Sites Services
SITES_SERVICES_URL=http://localhost:3001/api/v1/sites
SITES_SERVICES_TIMEOUT_MS=6000
SITES_SERVICES_CACHE_TTL_MS=120000

CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Grafana
GRAFANA_BASE_URL=http://grafana.sundaya.local/d/site-analysis/
GRAFANA_SITE_VAR=SiteID

# Connectivity probe (modul internal)
CONNECTIVITY_PROBE_ENABLED=true # enable connectivity probe
CONNECTIVITY_PROBE_INTERVAL_MS=180000 # 3 minutes
CONNECTIVITY_PROBE_TIMEOUT_MS=3000 # 3 seconds
CONNECTIVITY_PROBE_CONCURRENCY=10 # 10 concurrent probes
CONNECTIVITY_PROBE_MODE=tcp # tcp mode
CONNECTIVITY_PROBE_TCP_PORT=161 # 161 is the default port for SNMP
CONNECTIVITY_CACHE_TTL_MS=300000 # 5 minutes
